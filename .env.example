# Public site URL (sitemap, canonical URLs, llms.txt)
PUBLIC_SITE_URL=https://panunkaergar.com

# Admin API base URL for website booking form submissions (no trailing slash)
# Production: https://live.panunkaergar.com
# Dev: https://dev.panunkaergar.com
# Submits to POST {PUBLIC_ADMIN_API_URL}/api/v1/public/web-booking/submit
# and POST {PUBLIC_ADMIN_API_URL}/api/v1/public/web-provider-request/submit
PUBLIC_ADMIN_API_URL=https://live.panunkaergar.com

# Optional: Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
PUBLIC_GA_MEASUREMENT_ID=

# --- Keystatic CMS (hosted admin for your team — NOT needed for static site build) ---
# GitHub repo that holds this project's content/ folder (owner/name)
# KEYSTATIC_GITHUB_REPO=your-org/panun-marketing
# Created when you first connect Keystatic to GitHub (see CMS.md)
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=
# PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
