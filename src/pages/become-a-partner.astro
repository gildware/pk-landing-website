  </style>

  <script>
    function initPartnerBenefits() {
      const root = document.querySelector('[data-partner-benefits]');
      if (!(root instanceof HTMLElement) || root.dataset.benefitsReady === '1') return;
      root.dataset.benefitsReady = '1';

      const items = [...root.querySelectorAll('[data-benefit-item]')];
      const card = root.querySelector('[data-benefit-card]');
      const img = root.querySelector('[data-benefit-card-img]');
      const kicker = root.querySelector('[data-benefit-card-kicker]');
      const title = root.querySelector('[data-benefit-card-title]');
      const text = root.querySelector('[data-benefit-card-text]');
      const badgeIcons = [...root.querySelectorAll('[data-benefit-badge-icon]')];
      if (!(card instanceof HTMLElement) || !(img instanceof HTMLImageElement) || !items.length) return;

      let activeIndex = 0;
      let switchTimer = 0;

      function activate(index) {
        const trigger = items[index];
        if (!(trigger instanceof HTMLElement) || index === activeIndex) return;

        activeIndex = index;
        items.forEach((item, i) => {
          const open = i === index;
          item.classList.toggle('is-open', open);
          item.setAttribute('aria-expanded', open ? 'true' : 'false');
        });

        card.setAttribute('aria-labelledby', trigger.id);
        card.classList.add('is-switching');
        window.clearTimeout(switchTimer);

        const nextTitle = trigger.getAttribute('data-benefit-title') || '';
        const nextDetail = trigger.getAttribute('data-benefit-detail') || '';
        const nextHighlight = trigger.getAttribute('data-benefit-highlight') || '';
        const nextImage = trigger.getAttribute('data-benefit-image') || '';
        const nextAlt = trigger.getAttribute('data-benefit-alt') || '';

        switchTimer = window.setTimeout(() => {
          if (kicker) kicker.textContent = nextHighlight;
          if (title) title.textContent = nextTitle;
          if (text) text.textContent = nextDetail;
          if (nextImage) {
            img.src = nextImage;
            img.alt = nextAlt;
          }
          badgeIcons.forEach((icon) => {
            icon.classList.toggle(
              'is-active',
              Number(icon.getAttribute('data-benefit-index')) === index,
            );
          });
          card.classList.remove('is-switching');
        }, 160);
      }

      items.forEach((item) => {
        item.addEventListener('click', () => {
          const index = Number(item.getAttribute('data-benefit-index'));
          if (Number.isNaN(index)) return;
          activate(index);
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPartnerBenefits);
    } else {
      initPartnerBenefits();
    }
    document.addEventListener('astro:page-load', initPartnerBenefits);
  </script>

