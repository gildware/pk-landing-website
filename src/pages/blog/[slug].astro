---
import PageLayout from '@/layouts/PageLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import BookingOptions from '@/components/BookingOptions.astro';
import { buildMeta } from '@/utils/seo';
import { getBlogPost, getBlogPosts, getSiteSettings } from '@/utils/reader';
import { articleSchema, breadcrumbSchema } from '@/utils/schema';

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await getBlogPost(slug!);
if (!post) return Astro.redirect('/404');

const site = await getSiteSettings();

const meta = buildMeta({
  title: post.displayTitle ?? post.slug,
  description: post.description,
  path: `/blog/${post.slug}`,
  ogType: 'article',
});

const schemas = [
  articleSchema({
    title: post.displayTitle ?? post.slug,
    description: post.description,
    slug: post.slug,
    publishedAt: String(post.publishedAt ?? ''),
  }),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog' },
    { name: post.displayTitle ?? post.slug, path: `/blog/${post.slug}` },
  ]),
];
---

<PageLayout meta={meta} schemas={schemas}>
  <Breadcrumbs
    items={[
      { name: 'Home', path: '/' },
      { name: 'Blog', path: '/blog' },
      { name: post.displayTitle ?? post.slug },
    ]}
  />

  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <header>
      <time class="text-sm text-slate-500" datetime={String(post.publishedAt)}>
        {post.publishedAt ? new Date(String(post.publishedAt)).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) : ''}
      </time>
      <h1 class="mt-3 text-4xl font-extrabold text-slate-900">{post.displayTitle}</h1>
      <p class="mt-4 text-lg text-slate-600">{post.description}</p>
    </header>
    {post.bodyHtml && <div class="prose prose-slate mt-10 max-w-none" set:html={post.bodyHtml} />}
  </article>

  <BookingOptions site={site} />
</PageLayout>
