---
import PageLayout from '@/layouts/PageLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { buildMeta } from '@/utils/seo';
import { getBlogPosts } from '@/utils/reader';

const posts = await getBlogPosts();

const meta = buildMeta({
  title: 'Home Service Guides for Srinagar — Panun Kaergar Blog',
  description:
    'Expert guides on plumbing, electrical, appliance repair, cleaning, salon at home, and pest control in Srinagar. Tips from Panun Kaergar.',
  path: '/blog',
});
---

<PageLayout meta={meta}>
  <Breadcrumbs items={[{ name: 'Home', path: '/' }, { name: 'Blog' }]} />

  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
    <h1 class="text-4xl font-extrabold text-slate-900">Blog</h1>
    <p class="mt-4 text-lg text-slate-600">Guides and tips for home services in Srinagar and Kashmir.</p>

    <ul class="mt-12 space-y-8">
      {
        posts.map((post) => (
          <li class="rounded-2xl border border-slate-200 p-6 shadow-sm transition hover:border-brand-300">
            <time class="text-sm text-slate-500" datetime={String(post.publishedAt)}>
              {post.publishedAt ? new Date(String(post.publishedAt)).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) : ''}
            </time>
            <h2 class="mt-2 text-2xl font-bold">
              <a href={`/blog/${post.slug}`} class="hover:text-brand-700">{post.displayTitle}</a>
            </h2>
            <p class="mt-2 text-slate-600">{post.description}</p>
            <a href={`/blog/${post.slug}`} class="mt-4 inline-block text-sm font-semibold text-brand-700 hover:underline">
              Read more →
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</PageLayout>
