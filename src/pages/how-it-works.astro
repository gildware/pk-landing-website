---
import PageLayout from '@/layouts/PageLayout.astro';
import BookingOptions from '@/components/BookingOptions.astro';
import { buildMeta } from '@/utils/seo';
import { getSiteSettings, getHomepage } from '@/utils/reader';

const site = await getSiteSettings();
const homepage = await getHomepage();

const meta = buildMeta({
  title: 'How to Book Home Services in Srinagar | Panun Kaergar',
  description:
    'Learn how to book a plumber, electrician, or AC technician in Srinagar. Call, WhatsApp, use our website form, or download the Panun Kaergar app.',
  path: '/how-it-works',
});
---

<PageLayout meta={meta}>
  <section class="section-pad mx-auto max-w-4xl">
    <h1 class="animate-fade-up text-4xl font-extrabold text-slate-900">How to book with Panun Kaergar</h1>
    <p class="mt-4 animate-fade-up text-lg text-slate-600 stagger-1">
      Booking a home service in Srinagar takes just a few minutes. Choose the option that suits you —
      phone, WhatsApp, our website, or the free app.
    </p>

    {
      homepage?.howItWorksSteps && (
        <ol class="mt-12 space-y-6">
          {homepage.howItWorksSteps.map((step, i) => (
            <li class:list={['card card-hover flex gap-6 p-6 animate-fade-up', `stagger-${Math.min(i + 1, 4)}`]}>
              <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand-600 text-lg font-bold text-white">
                {i + 1}
              </span>
              <div>
                <h2 class="text-xl font-bold text-slate-900">{step.title}</h2>
                <p class="mt-2 text-slate-600">{step.description}</p>
              </div>
            </li>
          ))}
        </ol>
      )
    }
  </section>

  <BookingOptions site={site} />
</PageLayout>
