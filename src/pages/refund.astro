---
import PageLayout from '@/layouts/PageLayout.astro';
import { buildMeta } from '@/utils/seo';
import { getSiteSettings } from '@/utils/reader';

const site = await getSiteSettings();

const meta = buildMeta({
  title: 'Refund Policy',
  description: 'Refund policy for Panun Kaergar home services in Kashmir.',
  path: '/refund',
});
---

<PageLayout meta={meta}>
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6 prose prose-slate">
    <h1>Refund Policy</h1>
    <p>
      Panun Kaergar aims to deliver quality home services across Srinagar and Kashmir. Refund
      eligibility depends on the service type, booking status, and work completed.
    </p>
    <h2>When refunds may apply</h2>
    <ul>
      <li>Service not delivered as confirmed in your booking</li>
      <li>Partner cancellation without a suitable reschedule option</li>
      <li>Duplicate or erroneous charges (verified by our support team)</li>
    </ul>
    <h2>How to request a refund</h2>
    <p>
      Contact us with your booking details by phone at <a href={`tel:${site.phone}`}>{site.phone}</a>,
      WhatsApp, or email at <a href={`mailto:${site.email}`}>{site.email}</a>. Our team will review
      your case and respond as soon as possible.
    </p>
    <h2>Processing time</h2>
    <p>
      Approved refunds are processed to your original payment method where applicable. Timing may
      vary depending on your bank or payment provider.
    </p>
    <p>
      <a href="/contact">Contact support</a> · <a href="/cancellation">Cancellation policy</a>
    </p>
  </section>
</PageLayout>
