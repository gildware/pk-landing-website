---
import PageLayout from '@/layouts/PageLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import StoreButton from '@/components/StoreButton.astro';
import Icon from '@/components/Icon.astro';
import { buildMeta } from '@/utils/seo';
import { getSiteSettings } from '@/utils/reader';

const site = await getSiteSettings();

const meta = buildMeta({
  title: 'Become a Service Provider in Srinagar | Panun Kaergar',
  description:
    'Join Panun Kaergar as a plumber, electrician, or home service provider in Srinagar. Get booking requests through the Provider app.',
  path: '/become-a-provider',
});

const benefits = [
  'Get booking requests for the services you offer',
  'Manage jobs, schedule, and earnings in the Provider app',
  'Build your reputation with customer reviews',
  'Clear commission and payment settlement',
];

const steps = [
  { n: 1, title: 'Download the Provider app', desc: 'Free on Google Play and the App Store.' },
  { n: 2, title: 'Sign up and add your details', desc: 'Tell us what services you offer and where you work.' },
  { n: 3, title: 'Get verified', desc: 'Our team checks your profile before you go live.' },
  { n: 4, title: 'Choose your service categories', desc: 'Pick carpentry, plumbing, electrician, cleaning, salon, appliances, or other categories to receive matching bookings.' },
  { n: 5, title: 'Accept jobs and earn', desc: 'Receive requests, complete jobs, and track payments in the app.' },
];
---

<PageLayout meta={meta}>
  <Breadcrumbs items={[{ name: 'Home', path: '/' }, { name: 'Become a provider' }]} />

  <section class="section-pad mx-auto max-w-3xl">
    <h1 class="animate-fade-up text-4xl font-extrabold text-slate-900">Join as a service provider</h1>
    <p class="mt-4 animate-fade-up text-lg text-slate-600 stagger-1">
      Are you a plumber, electrician, cleaner, or other skilled professional in Kashmir? Join Panun
      Kaergar to reach more customers in Srinagar through our Provider app.
    </p>

    <ul class="mt-10 grid gap-4 sm:grid-cols-2">
      {benefits.map((text, i) => (
        <li class:list={['card card-hover flex items-start gap-3 p-5 text-sm text-slate-700 animate-fade-up', `stagger-${Math.min(i + 1, 4)}`]}>
          <Icon name="check" size={20} class="mt-0.5 shrink-0 text-brand-600" />
          {text}
        </li>
      ))}
    </ul>

    <h2 class="mt-14 text-2xl font-bold text-slate-900">How to join</h2>
    <ol class="mt-8 space-y-4">
      {steps.map((s, i) => (
        <li class:list={['card card-hover flex gap-4 p-5 animate-fade-up', `stagger-${Math.min(i + 1, 4)}`]}>
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-600 text-sm font-bold text-white">{s.n}</span>
          <div>
            <h3 class="font-bold text-slate-900">{s.title}</h3>
            <p class="mt-1 text-sm text-slate-600">{s.desc}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="mt-12 flex flex-col gap-4 sm:flex-row animate-fade-up">
      <StoreButton store="google-play" href={site.providerPlayStoreUrl} />
      <StoreButton store="app-store" href={site.providerAppStoreUrl} />
    </div>

    <p class="mt-10 text-sm text-slate-600">
      Questions about joining? Call <a href={`tel:${site.phone}`} class="font-medium text-brand-700">{site.phone}</a> or
      <a href={`https://wa.me/${site.whatsapp.replace(/\D/g, '')}`} class="font-medium text-brand-700"> WhatsApp us</a>.
    </p>
  </section>
</PageLayout>
