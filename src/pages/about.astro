      grid-template-columns: 1.2fr 0.9fr 0.9fr;
      grid-template-rows: 1fr 1fr;
      min-height: 20rem;
    }

    .about-hero-mosaic__cell--1 {
      grid-column: 1;
      grid-row: 1 / span 2;
    }

    .about-hero-mosaic__cell--2 {
      grid-column: 2;
      grid-row: 1;
    }

    .about-hero-mosaic__cell--3 {
      grid-column: 2;
