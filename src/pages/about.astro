</style>

<script>
  function initAboutGallery() {
    const root = document.querySelector('[data-about-gallery]');
    const track = root?.querySelector('[data-gallery-track]');
    const prevBtn = root?.querySelector('[data-gallery-prev]');
    const nextBtn = root?.querySelector('[data-gallery-next]');
    if (!(root instanceof HTMLElement) || !(track instanceof HTMLElement)) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let offset = 0;
    let paused = false;
    let resumeTimer = 0;
    let halfWidth = 0;
    let raf = 0;
    const speed = 0.42;

    function measure() {
      halfWidth = track.scrollWidth / 2;
    }

    function apply() {
      if (halfWidth > 0) {
        while (offset <= -halfWidth) offset += halfWidth;
        while (offset > 0) offset -= halfWidth;
      }
      track.style.transform = `translate3d(${offset}px, 0, 0)`;
    }

    function nudge(delta) {
      paused = true;
      window.clearTimeout(resumeTimer);
      offset += delta;
      apply();
      if (!reduceMotion) {
        resumeTimer = window.setTimeout(() => {
          paused = false;
        }, 2200);
      }
    }

    function tick() {
      if (!paused && !reduceMotion && halfWidth > 0) {
        offset -= speed;
        apply();
      }
      raf = window.requestAnimationFrame(tick);
    }

    measure();
    apply();

    if (!reduceMotion) {
      raf = window.requestAnimationFrame(tick);
    }

    root.addEventListener('mouseenter', () => {
      paused = true;
    });
    root.addEventListener('mouseleave', () => {
      if (!reduceMotion) paused = false;
    });

    prevBtn?.addEventListener('click', () => nudge(240));
    nextBtn?.addEventListener('click', () => nudge(-240));

    window.addEventListener(
      'resize',
      () => {
        measure();
        apply();
      },
      { passive: true },
    );

    window.addEventListener('beforeunload', () => {
      window.cancelAnimationFrame(raf);
      window.clearTimeout(resumeTimer);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAboutGallery);
  } else {
    initAboutGallery();
  }
</script>
