---
import PageLayout from '@/layouts/PageLayout.astro';
import BookServiceForm from '@/components/BookServiceForm.astro';
import BookingOptions from '@/components/BookingOptions.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { buildMeta } from '@/utils/seo';
import { getSiteSettings, getServices } from '@/utils/reader';
import { breadcrumbSchema } from '@/utils/schema';

const site = await getSiteSettings();
const services = await getServices();

const meta = buildMeta({
  title: 'Book a Home Service in Srinagar | Panun Kaergar',
  description:
    'Book a plumber, electrician, AC technician, or cleaner in Srinagar. Call +91 8899 181 555, WhatsApp us, fill our online form, or use the free app.',
  path: '/book',
});

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Book', path: '/book' },
  ]),
];
---

<PageLayout meta={meta} schemas={schemas}>
  <Breadcrumbs items={[{ name: 'Home', path: '/' }, { name: 'Book a service' }]} />

  <section class="mx-auto max-w-3xl px-4 pb-4 pt-8 text-center sm:px-6">
    <h1 class="text-4xl font-extrabold text-slate-900">Book a home service in Srinagar</h1>
    <p class="mt-4 text-lg text-slate-600">
      Call, WhatsApp, or fill the form below. We match you with a verified provider in your area.
    </p>
  </section>

  <BookingOptions site={site} variant="compact" showHeading={false} showFormLink={false} />

  <BookServiceForm site={site} services={services} heading="Fill in the booking form" />

  <section class="mx-auto max-w-2xl px-4 pb-16 text-center text-sm text-slate-500 sm:px-6">
    <p>
      Business hours: {(site as { businessHours?: string }).businessHours ?? 'Mon–Sun: 8:00 AM – 9:00 PM'}
    </p>
  </section>
</PageLayout>
