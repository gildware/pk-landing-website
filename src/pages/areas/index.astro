---
import PageLayout from '@/layouts/PageLayout.astro';
import BookingOptions from '@/components/BookingOptions.astro';
import Icon from '@/components/Icon.astro';
import { buildMeta } from '@/utils/seo';
import { getSiteSettings, getAreas, getServices } from '@/utils/reader';
import { breadcrumbSchema } from '@/utils/schema';

const site = await getSiteSettings();
const areas = await getAreas();
const services = await getServices();

const meta = buildMeta({
  title: 'Service Areas — Home Services in Srinagar & Kashmir',
  description:
    'See where Panun Kaergar offers carpentry, plumbing, electrician, cleaning, salon, and more. Book verified providers across Srinagar neighborhoods.',
  path: '/areas',
});

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Areas', path: '/areas' },
  ]),
];
---

<PageLayout meta={meta} schemas={schemas}>
  <section class="section-pad mx-auto max-w-6xl">
    <h1 class="animate-fade-up text-4xl font-extrabold text-slate-900">Where we serve</h1>
    <p class="mt-4 max-w-2xl animate-fade-up text-lg text-slate-600 stagger-1">
      Panun Kaergar offers home services in Srinagar and surrounding areas. Select your city to see
      available services and book online.
    </p>

    <div class="mt-12 grid gap-8 md:grid-cols-2">
      {
        areas.map((area, i) => (
          <article class:list={['card card-hover p-8 animate-fade-up', `stagger-${Math.min(i + 1, 4)}`]}>
            <div class="flex items-center gap-3">
              <span class="icon-badge">
                <Icon name="map-pin" size={20} class="text-brand-600" />
              </span>
              <h2 class="text-2xl font-bold">
                <a href={`/areas/${area.slug}`} class="text-slate-900 hover:text-brand-700">
                  {area.displayName}
                </a>
              </h2>
            </div>
            <p class="mt-2 text-sm text-slate-500">{area.region}</p>
            <p class="mt-4 text-sm text-slate-600">{area.description}</p>
            <div class="mt-6 flex flex-wrap gap-2">
              {services.slice(0, 4).map((s) => (
                <a
                  href={`/services/${s.slug}/${area.slug}`}
                  class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700 transition hover:bg-brand-50 hover:text-brand-700"
                >
                  {s.shortName}
                </a>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <BookingOptions site={site} variant="compact" />
</PageLayout>
