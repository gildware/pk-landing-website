---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/Icon.astro';
import { buildMeta } from '@/utils/seo';

const meta = buildMeta({
  title: 'Page not found',
  description: 'The page you are looking for could not be found.',
  path: '/404',
  noindex: true,
});
---

<PageLayout meta={meta}>
  <section class="mx-auto max-w-lg px-4 py-24 text-center sm:px-6">
    <p class="animate-fade-up text-6xl font-extrabold text-brand-700">404</p>
    <h1 class="mt-4 animate-fade-up text-2xl font-bold text-slate-900 stagger-1">Page not found</h1>
    <p class="mt-3 animate-fade-up text-slate-600 stagger-2">The page you're looking for doesn't exist or has moved.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3 animate-fade-up stagger-3">
      <a href="/" class="btn-secondary">Go home</a>
      <a href="/book" class="btn-primary inline-flex items-center gap-2">
        Book a service
        <Icon name="chevron-right" size={16} />
      </a>
    </div>
  </section>
</PageLayout>
