---
import { categoryIcon } from '@/utils/categoryCatalog';

interface Props {
  categories: { slug: string; shortName: string }[];
  currentSlug: string;
  bookHref: string;
  /** CTA label, e.g. “Book Carpenter in Budgam” or “Book Men's Salon Services”. Defaults to “Book Now”. */
  bookButtonText?: string;
  /** When set, category links go to /services/{slug}/{areaSlug} for local SEO. */
  areaSlug?: string;
  areaName?: string;
}

const {
  categories,
  currentSlug,
  bookHref,
  bookButtonText = 'Book Now',
  areaSlug,
  areaName,
} = Astro.props;
const others = categories.filter((c) => c.slug !== currentSlug);
const hrefFor = (slug: string) =>
  areaSlug ? `/services/${slug}/${areaSlug}` : `/services/${slug}`;
---

<aside class="category-sidebar space-y-6 lg:sticky lg:top-24">
  <div class="rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm">
    <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-500">
      {areaName ? `Other Services in ${areaName}` : 'Other Categories'}
    </p>
    <nav class="mt-3 max-h-[min(28rem,55vh)] space-y-0.5 overflow-y-auto pr-1" aria-label="Other service categories">
      {
        others.map((cat) => (
          <a
            href={hrefFor(cat.slug)}
            class="flex items-center gap-3 rounded-xl px-2.5 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-brand-700"
          >
            <img
              src={categoryIcon(cat.slug)}
              alt=""
              width="96"
              height="96"
              class="h-7 w-7 shrink-0 object-contain"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
            <span class="truncate">{cat.shortName}</span>
          </a>
        ))
      }
    </nav>
    <a
      href={areaSlug ? `/services/${currentSlug}` : '/services'}
      class="mt-3 block text-center text-sm font-semibold text-brand-700 hover:text-brand-800"
    >
      {areaSlug ? 'View category overview' : 'View All Services'}
    </a>
  </div>

  <div
    class="rounded-2xl px-5 py-6 text-white"
    style="background: linear-gradient(145deg, #202048 0%, #2d3a7c 55%, #1e3a5f 100%);"
  >
    <p class="text-lg font-bold tracking-tight">Ready to Book?</p>
    <p class="mt-2 text-sm leading-relaxed text-white/80">
      {
        areaName
          ? `Call, WhatsApp, use the website form, or book in the app — verified partners in ${areaName}.`
          : 'Call, WhatsApp, use the website form, or book in the app — verified partners across Kashmir.'
      }
    </p>
    <a
      href={bookHref}
      class="mt-4 inline-flex w-full items-center justify-center rounded-full bg-white px-4 py-2.5 text-sm font-semibold text-[#202048] transition hover:bg-slate-100"
    >
      {bookButtonText}
    </a>
  </div>
</aside>
