---
/**
 * Single-line slow marquee of service categories with icons.
 */
import { categoryIcon } from '@/utils/categoryCatalog';

interface CategoryItem {
  slug: string;
  shortName: string;
}

interface Props {
  categories: CategoryItem[];
}

const { categories } = Astro.props;

const items = categories.map((cat) => ({
  ...cat,
  icon: categoryIcon(cat.slug),
}));

const loop = [...items, ...items];
---

<section class="category-marquee" aria-label="Service categories">
  <p class="sr-only">
    Services include {categories.map((c) => c.shortName).join(', ')}.
  </p>

  <div class="category-marquee__row" aria-hidden="true">
    <div class="category-marquee__track">
      {
        loop.map((cat) => (
          <a href={`/services/${cat.slug}`} class="category-marquee__item" tabindex="-1">
            <img
              src={cat.icon}
              alt=""
              width="96"
              height="96"
              class="category-marquee__icon"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
            <span>{cat.shortName}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .category-marquee {
    position: relative;
    overflow: hidden;
    background: #f8fafc;
    border-bottom: 1px solid rgb(226 232 240);
    padding: 1.1rem 0;
  }

  .category-marquee__row {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, #000 5%, #000 95%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, #000 5%, #000 95%, transparent);
  }

  .category-marquee__track {
    display: flex;
    width: max-content;
    align-items: center;
    gap: 2.25rem;
    padding-inline: 1rem;
    will-change: transform;
    animation: category-marquee-scroll 75s linear infinite;
  }

  .category-marquee__item {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: Figtree, system-ui, sans-serif;
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    color: #0f172a;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.25s ease;
  }

  .category-marquee__item:hover {
    color: #1e3a8a;
  }

  .category-marquee__icon {
    width: 2rem;
    height: 2rem;
    object-fit: contain;
    flex-shrink: 0;
  }

  .category-marquee:hover .category-marquee__track {
    animation-play-state: paused;
  }

  @keyframes category-marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .category-marquee__track {
      animation: none;
    }

    .category-marquee__row {
      overflow-x: auto;
      mask-image: none;
      -webkit-mask-image: none;
    }
  }

  @media (min-width: 640px) {
    .category-marquee {
      padding: 1.35rem 0;
    }

    .category-marquee__track {
      gap: 2.75rem;
    }

    .category-marquee__icon {
      width: 2.35rem;
      height: 2.35rem;
    }
  }
</style>
