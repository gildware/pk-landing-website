---
import Icon from '@/components/Icon.astro';
import { areaPath, SERVICE_AREAS_PATH } from '@/utils/areaPaths';
import { areaImage } from '@/utils/areaVisuals';

interface Props {
  areas: { slug: string; displayName: string }[];
  currentSlug: string;
  bookHref: string;
  districtName: string;
}

const { areas, currentSlug, bookHref, districtName } = Astro.props;
const others = areas.filter((a) => a.slug !== currentSlug);
---

<aside class="area-sidebar space-y-6 lg:sticky lg:top-24">
  <div class="rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm">
    <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-500">
      Other Districts
    </p>
    <nav
      class="mt-3 max-h-[min(28rem,55vh)] space-y-0.5 overflow-y-auto pr-1"
      aria-label="Other service areas"
    >
      {
        others.map((area) => (
          <a
            href={areaPath(area.slug)}
            class="flex items-center gap-3 rounded-xl px-2.5 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-brand-700"
          >
            <span class="relative h-8 w-8 shrink-0 overflow-hidden rounded-lg bg-slate-100 ring-1 ring-slate-200/80">
              <img
                src={areaImage(area.slug)}
                alt=""
                width="32"
                height="32"
                class="h-full w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </span>
            <span class="truncate">{area.displayName}</span>
          </a>
        ))
      }
    </nav>
    <a
      href={SERVICE_AREAS_PATH}
      class="mt-3 block text-center text-sm font-semibold text-brand-700 hover:text-brand-800"
    >
      View All Districts
    </a>
  </div>

  <div
    class="rounded-2xl px-5 py-6 text-white"
    style="background: linear-gradient(145deg, #202048 0%, #2d3a7c 55%, #1e3a5f 100%);"
  >
    <p class="text-lg font-bold tracking-tight">Ready to Book?</p>
    <p class="mt-2 text-sm leading-relaxed text-white/80">
      Call, WhatsApp, use the website form, or book in the app — verified partners in{' '}
      {districtName}.
    </p>
    <a
      href={bookHref}
      class="mt-4 inline-flex w-full items-center justify-center rounded-full bg-white px-4 py-2.5 text-sm font-semibold text-[#202048] transition hover:bg-slate-100"
    >
      Book Now
    </a>
    <p class="mt-3 flex items-center justify-center gap-1.5 text-xs text-white/60">
      <Icon name="map-pin" size={12} />
      Serving {districtName}, Kashmir
    </p>
  </div>
</aside>
