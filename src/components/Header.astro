---
import { getServices } from '@/utils/reader';
import { groupServices } from '@/utils/serviceGroups';
import { BOOK_PATH } from '@/utils/booking';

interface SiteNav {
  businessName: string;
  bookingUrl: string;
}

interface Props {
  site: SiteNav;
}

const { site } = Astro.props;
const services = await getServices();
const serviceGroups = groupServices(
  services.map((s) => ({ slug: s.slug, shortName: s.shortName })),
);

type NavLink = { href: string; label: string };
type NavItem =
  | { label: string; href: string; kind?: 'links'; children: NavLink[] }
  | { label: string; href: string; kind: 'service-hierarchy'; groups: typeof serviceGroups }
  | { label: string; href: string; kind?: undefined; children?: undefined };

const nav: NavItem[] = [
  {
    label: 'Services',
    href: '/services',
    kind: 'service-hierarchy',
    groups: serviceGroups,
  },
  { label: 'Areas', href: '/service-areas' },
  {
    label: 'Resources',
    href: '/faq',
    children: [
      { href: '/faq', label: 'FAQ' },
      { href: '/about', label: 'About Us' },
      { href: '/download', label: 'Download App' },
    ],
  },
  { label: 'Become A Partner', href: '/become-a-partner' },
];

const mobileNav = [
  { href: '/service-areas', label: 'Areas' },
  { href: '/faq', label: 'FAQ' },
  { href: '/about', label: 'About' },
  { href: '/become-a-partner', label: 'Become A Partner' },
  { href: '/download', label: 'Download App' },
  { href: '/contact', label: 'Contact' },
];
---

<header
  id="site-header"
  class="sticky top-0 z-50 bg-white font-figtree transition-shadow duration-500 ease-smooth"
>
  <div class="relative mx-auto flex h-[72px] max-w-[1400px] items-center justify-between gap-6 px-5 sm:px-8 lg:px-10">
    <div class="flex min-w-0 items-center gap-8 lg:gap-10">
      <a href="/" class="flex h-[34px] shrink-0 items-center" aria-label={site.businessName}>
        <picture>
          <source srcset="/logo-header.webp" type="image/webp" />
          <img
            src="/logo.png"
            alt={site.businessName}
            width="139"
            height="34"
            decoding="async"
            class="h-[34px] w-[139px] object-contain object-left"
          />
        </picture>
      </a>

      <nav class="hidden items-center gap-1 lg:flex" aria-label="Main">
        {
          nav.map((item) =>
            item.kind === 'service-hierarchy' ? (
              <div class="nav-dropdown group/services relative">
                <a
                  href={item.href}
                  class="inline-flex items-center gap-1 rounded-md px-3 py-2 text-[15px] font-medium text-[#323338] transition-colors duration-200 hover:bg-slate-50 hover:text-brand-700"
                >
                  {item.label}
                  <svg class="h-3.5 w-3.5 text-[#676879] transition-transform duration-200 group-hover/services:rotate-180 group-focus-within/services:rotate-180" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
                <div class="invisible absolute left-0 top-full z-50 pt-2 opacity-0 transition-all duration-200 group-hover/services:visible group-hover/services:opacity-100 group-focus-within/services:visible group-focus-within/services:opacity-100">
                  <ul class="min-w-[260px] rounded-xl border border-slate-200/80 bg-white py-2 shadow-lg shadow-slate-900/8">
                    <li>
                      <a
                        href="/services"
                        class="block px-4 py-2.5 text-sm font-semibold text-brand-700 transition-colors hover:bg-slate-50"
                      >
                        All Services
                      </a>
                    </li>
                    {item.groups.map((group) => (
                      <li class="group/flyout relative">
                        <button
                          type="button"
                          class="flex w-full items-center justify-between gap-3 px-4 py-2.5 text-left text-sm font-medium text-[#323338] transition-colors hover:bg-slate-50 hover:text-brand-700 group-hover/flyout:bg-slate-50 group-hover/flyout:text-brand-700 group-focus-within/flyout:bg-slate-50 group-focus-within/flyout:text-brand-700"
                        >
                          <span>{group.label}</span>
                          <svg class="h-3.5 w-3.5 shrink-0 text-[#676879]" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                            <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        </button>
                        <div class="invisible absolute left-full top-0 z-50 pl-1.5 opacity-0 transition-all duration-150 group-hover/flyout:visible group-hover/flyout:opacity-100 group-focus-within/flyout:visible group-focus-within/flyout:opacity-100">
                          <ul class="min-w-[220px] rounded-xl border border-slate-200/80 bg-white py-2 shadow-lg shadow-slate-900/8">
                            {group.services.map((service) => (
                              <li>
                                <a
                                  href={`/services/${service.slug}`}
                                  class="block px-4 py-2.5 text-sm font-medium text-[#323338] transition-colors hover:bg-slate-50 hover:text-brand-700"
                                >
                                  {service.shortName}
                                </a>
                              </li>
                            ))}
                          </ul>
                        </div>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ) : item.children ? (
              <div class="nav-dropdown group relative">
                <a
                  href={item.href}
                  class="inline-flex items-center gap-1 rounded-md px-3 py-2 text-[15px] font-medium text-[#323338] transition-colors duration-200 hover:bg-slate-50 hover:text-brand-700"
                >
                  {item.label}
                  <svg class="h-3.5 w-3.5 text-[#676879] transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
                <div class="nav-dropdown-panel invisible absolute left-0 top-full z-50 pt-2 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                  <ul class="min-w-[220px] rounded-xl border border-slate-200/80 bg-white py-2 shadow-lg shadow-slate-900/8">
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          class="block px-4 py-2.5 text-sm font-medium text-[#323338] transition-colors hover:bg-slate-50 hover:text-brand-700"
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class="rounded-md px-3 py-2 text-[15px] font-medium text-[#323338] transition-colors duration-200 hover:bg-slate-50 hover:text-brand-700"
              >
                {item.label}
              </a>
            )
          )
        }
      </nav>
    </div>

    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href="/download"
        class="hidden text-[15px] font-medium text-[#323338] transition-colors hover:text-brand-700 md:inline"
      >
        Download App
      </a>
      <a
        href="/contact"
        class="hidden items-center justify-center rounded-full border border-brand-600 px-4 py-2 text-[14px] font-medium text-brand-600 transition-colors duration-200 hover:bg-brand-50 sm:inline-flex"
      >
        Contact Us
      </a>
      <a
        href={BOOK_PATH}
        class="inline-flex items-center justify-center gap-1.5 rounded-full bg-brand-600 px-4 py-2 text-[14px] font-medium text-white transition-colors duration-200 hover:bg-brand-700 sm:px-5"
      >
        Book Now
        <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
      <button
        type="button"
        id="mobile-menu-btn"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-[#323338] transition hover:bg-slate-100 lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg id="menu-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div
      id="mobile-menu"
      class="absolute left-0 right-0 top-full hidden max-h-[calc(100dvh-72px)] overflow-y-auto border-t border-slate-200 bg-white px-5 py-4 shadow-lg sm:px-8 lg:hidden"
    >
      <div class="mb-3">
        <a
          href="/services"
          class="mobile-nav-link block rounded-lg px-3 py-2 text-[15px] font-semibold text-brand-700 hover:bg-slate-50"
        >
          All Services
        </a>
        {
          serviceGroups.map((group) => (
            <details class="group/mobile-svc mt-1 rounded-lg">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-2 rounded-lg px-3 py-2.5 text-[15px] font-medium text-[#323338] hover:bg-slate-50 hover:text-brand-700 [&::-webkit-details-marker]:hidden">
                <span>{group.label}</span>
                <svg class="h-3.5 w-3.5 shrink-0 text-[#676879] transition-transform duration-200 group-open/mobile-svc:rotate-180" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </summary>
              <ul class="mb-1 ml-2 border-l border-slate-200 pl-2">
                {group.services.map((service) => (
                  <li>
                    <a
                      href={`/services/${service.slug}`}
                      class="mobile-nav-link block rounded-lg px-3 py-2 text-[14px] font-medium text-[#323338] hover:bg-slate-50 hover:text-brand-700"
                    >
                      {service.shortName}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ))
        }
      </div>
      <ul class="border-t border-slate-100 pt-2">
        {
          mobileNav.map((item) => (
            <li>
              <a
                href={item.href}
                class="mobile-nav-link block rounded-lg px-3 py-2.5 text-[15px] font-medium text-[#323338] hover:bg-slate-50 hover:text-brand-700"
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="mt-2 border-t border-slate-100 pt-3">
          <a
            href={BOOK_PATH}
            class="mobile-nav-link flex items-center justify-center gap-1.5 rounded-full bg-brand-600 px-4 py-2.5 text-sm font-medium text-white"
          >
            Book Now
            <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    openIcon?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      btn?.setAttribute('aria-label', 'Open menu');
    });
  });
</script>
