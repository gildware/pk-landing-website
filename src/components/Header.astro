---
interface SiteNav {
  businessName: string;
  bookingUrl: string;
}

interface Props {
  site: SiteNav;
}

const { site } = Astro.props;
const nav = [
  { href: '/services', label: 'Services' },
  { href: '/areas', label: 'Areas' },
  { href: '/how-it-works', label: 'How it works' },
  { href: '/faq', label: 'FAQ' },
  { href: '/about', label: 'About' },
  { href: '/become-a-provider', label: 'Become a provider' },
];
---

<header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/95 backdrop-blur-md transition-shadow duration-300">
  <div class="relative mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="flex h-[50px] shrink-0 items-center py-0.5" aria-label={site.businessName}>
      <picture>
        <source srcset="/logo-header.webp" type="image/webp" />
        <img
          src="/logo.png"
          alt={site.businessName}
          width="205"
          height="50"
          decoding="async"
          fetchpriority="high"
          class="h-[50px] w-[205px] max-w-[13rem] object-contain object-left"
        />
      </picture>
    </a>

    <nav class="flex items-center gap-2 lg:gap-5" aria-label="Main">
      <ul class="hidden items-center gap-5 text-sm font-medium text-slate-600 lg:flex">
        {nav.map((item) => (
          <li>
            <a href={item.href} class="transition-colors duration-200 hover:text-brand-700">{item.label}</a>
          </li>
        ))}
      </ul>

      <div class="flex items-center gap-2">
        <a
          href="/download"
          class="hidden rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-100 md:inline-block"
        >
          Download app
        </a>
        <a href="/#book-form" class="btn-primary px-4 py-2.5 text-sm sm:px-5">
          Book now
        </a>
        <button
          type="button"
          id="mobile-menu-btn"
          class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-slate-600 transition hover:bg-slate-100 lg:hidden"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Open menu"
        >
          <svg id="menu-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="menu-icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <ul
        id="mobile-menu"
        class="absolute left-0 right-0 top-full hidden border-t border-slate-200 bg-white px-4 py-4 lg:hidden"
      >
        {nav.map((item) => (
          <li>
            <a href={item.href} class="mobile-nav-link block rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-brand-700">
              {item.label}
            </a>
          </li>
        ))}
        <li>
          <a href="/download" class="mobile-nav-link block rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50">
            Download app
          </a>
        </li>
        <li>
          <a href="/contact" class="mobile-nav-link block rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50">
            Contact
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    openIcon?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      btn?.setAttribute('aria-label', 'Open menu');
    });
  });
</script>
