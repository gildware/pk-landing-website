---
/**
 * Single-line slow marquee of districts — matches CategoryMarquee style.
 */
import Icon from '@/components/Icon.astro';
import { areaPath } from '@/utils/areaPaths';

interface AreaItem {
  slug: string;
  displayName: string;
}

interface Props {
  areas: AreaItem[];
}

const { areas } = Astro.props;
const loop = [...areas, ...areas];
---

<section class="areas-marquee" aria-label="Districts we serve">
  <p class="sr-only">
    We serve {areas.map((a) => a.displayName).join(', ')}.
  </p>

  <div class="areas-marquee__row" aria-hidden="true">
    <div class="areas-marquee__track">
      {
        loop.map((area) => (
          <a href={areaPath(area.slug)} class="areas-marquee__item" tabindex="-1">
            <span class="areas-marquee__icon">
              <Icon name="map-pin" size={22} />
            </span>
            <span>{area.displayName}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .areas-marquee {
    position: relative;
    overflow: hidden;
    margin-top: 1.75rem;
    background: #f8fafc;
    border-bottom: 1px solid rgb(226 232 240);
    border-top: 1px solid rgb(226 232 240);
    padding: 1.1rem 0;
  }

  .areas-marquee__row {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, #000 5%, #000 95%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, #000 5%, #000 95%, transparent);
  }

  .areas-marquee__track {
    display: flex;
    width: max-content;
    align-items: center;
    gap: 2.25rem;
    padding-inline: 1rem;
    will-change: transform;
    animation: areas-marquee-scroll 75s linear infinite;
  }

  .areas-marquee__item {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: Figtree, system-ui, sans-serif;
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    color: #0f172a;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.25s ease;
  }

  .areas-marquee__item:hover {
    color: #1e3a8a;
  }

  .areas-marquee__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    color: #1e3a8a;
  }

  .areas-marquee:hover .areas-marquee__track {
    animation-play-state: paused;
  }

  @keyframes areas-marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .areas-marquee__track {
      animation: none;
    }

    .areas-marquee__row {
      overflow-x: auto;
      mask-image: none;
      -webkit-mask-image: none;
    }
  }

  @media (min-width: 640px) {
    .areas-marquee {
      padding: 1.35rem 0;
    }

    .areas-marquee__track {
      gap: 2.75rem;
    }

    .areas-marquee__icon {
      width: 2.35rem;
      height: 2.35rem;
    }
  }
</style>
