---
interface Crumb {
  name: string;
  path?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mx-auto max-w-6xl px-4 pt-6 sm:px-6">
  <ol class="flex flex-wrap items-center gap-1 text-sm text-slate-500">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-1">
          {i > 0 && <span aria-hidden="true" class="text-slate-300">/</span>}
          {item.path ? (
            <a href={item.path} class="hover:text-brand-700">
              {item.name}
            </a>
          ) : (
            <span class="font-medium text-slate-800">{item.name}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
