---
interface Testimonial {
  customerName: string;
  location: string;
  service: string;
  quote: string;
  rating: number;
}

interface Props {
  title?: string;
  items: Testimonial[];
}

const { title = 'What our customers say', items } = Astro.props;
---

{
  items.length > 0 && (
    <section class="section-pad bg-slate-50" aria-labelledby="testimonials-heading">
      <div class="mx-auto max-w-6xl">
        <h2 id="testimonials-heading" class="reveal text-center text-3xl font-bold text-slate-900">
          {title}
        </h2>
        <p class="reveal reveal-stagger-1 mx-auto mt-3 max-w-xl text-center text-slate-600">
          Real reviews from homeowners in Srinagar — plumbing, electrical, appliances, salon, and more.
        </p>

        <div class="relative mt-10">
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {items.map((item, i) => (
              <figure class:list={['reveal-scale card card-hover flex flex-col p-6', `reveal-stagger-${Math.min(i + 1, 6)}`]}>
                <p class="text-base leading-none tracking-wider text-amber-400" role="img" aria-label={`${item.rating} out of 5 stars`}>
                  {'★'.repeat(item.rating)}
                </p>
                <blockquote class="mt-4 flex-1 text-sm leading-relaxed text-slate-700">
                  "{item.quote}"
                </blockquote>
                <figcaption class="mt-4 border-t border-slate-100 pt-4">
                  <p class="font-semibold text-slate-900">{item.customerName}</p>
                  <p class="text-xs text-slate-500">
                    {item.location} · {item.service}
                  </p>
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}
