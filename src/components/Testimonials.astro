---
import Icon from '@/components/Icon.astro';

interface Testimonial {
  customerName: string;
  location: string;
  service: string;
  quote: string;
  rating: number;
}

interface Props {
  title?: string;
  items: Testimonial[];
}

const { title = 'What our customers say', items } = Astro.props;
---

{
  items.length > 0 && (
    <section class="section-pad bg-slate-50" aria-labelledby="testimonials-heading">
      <div class="mx-auto max-w-6xl">
        <h2 id="testimonials-heading" class="animate-fade-up text-center text-3xl font-bold text-slate-900">
          {title}
        </h2>
        <p class="mx-auto mt-3 max-w-xl animate-fade-up text-center text-slate-600 stagger-1">
          Real reviews from homeowners in Srinagar — plumbing, electrical, appliances, salon, and more.
        </p>

        <div class="relative mt-10 animate-fade-up stagger-2">
          <div
            class="scroll-row -mx-4 px-4 sm:-mx-6 sm:px-6"
            role="region"
            aria-label="Customer reviews — scroll horizontally to read more"
            tabindex="0"
          >
            {items.map((item) => (
              <figure class="card card-hover flex w-[min(85vw,22rem)] flex-col p-6 sm:w-[22rem]">
                <p class="text-base leading-none tracking-wider text-amber-400" role="img" aria-label={`${item.rating} out of 5 stars`}>
                  {'★'.repeat(item.rating)}
                </p>
                <blockquote class="mt-4 flex-1 text-sm leading-relaxed text-slate-700">
                  "{item.quote}"
                </blockquote>
                <figcaption class="mt-4 border-t border-slate-100 pt-4">
                  <p class="font-semibold text-slate-900">{item.customerName}</p>
                  <p class="text-xs text-slate-500">
                    {item.location} · {item.service}
                  </p>
                </figcaption>
              </figure>
            ))}
          </div>

          <p class="mt-4 flex items-center justify-center gap-1.5 text-center text-xs text-slate-500 sm:hidden">
            <Icon name="chevron-right" size={14} class="text-brand-500" aria-hidden="true" />
            Swipe for more reviews
          </p>
          <p class="mt-4 hidden text-center text-xs text-slate-500 sm:block">
            Scroll sideways to read all {items.length} reviews
          </p>
        </div>
      </div>
    </section>
  )
}
