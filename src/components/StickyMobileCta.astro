---
import type { BookingSite } from '@/utils/booking';
import { BOOK_PATH, whatsappHref, generalWhatsAppMessage } from '@/utils/booking';
import Icon from '@/components/Icon.astro';

interface Props {
  site: BookingSite;
}

const { site } = Astro.props;
const wa = whatsappHref(site.whatsapp, generalWhatsAppMessage());

const items = [
  {
    href: `tel:${site.phone}`,
    label: 'Call us',
    icon: 'phone',
    className: 'text-slate-700 [&_svg]:text-brand-600',
    external: false,
  },
  {
    href: wa,
    label: 'WhatsApp us',
    icon: 'whatsapp',
    className: 'text-whatsapp-dark',
    external: true,
  },
  {
    href: '/download',
    label: 'Download app',
    icon: 'smartphone',
    className: 'text-slate-700 [&_svg]:text-orange-600',
    external: false,
  },
  {
    href: BOOK_PATH,
    label: 'Book now',
    icon: 'form',
    className: 'text-slate-700 [&_svg]:text-brand-600',
    external: false,
  },
] as const;
---

<nav
  class="fixed bottom-0 left-0 right-0 z-40 border-t border-slate-200 bg-white/95 px-2 py-2 shadow-lg backdrop-blur-md xl:hidden"
  aria-label="Quick booking"
>
  <div class="mx-auto flex max-w-2xl items-center justify-between gap-1 sm:gap-2">
    {
      items.map((item) => (
        <a
          href={item.href}
          class:list={[
            'flex flex-1 flex-col items-center gap-0.5 rounded-lg py-1.5 text-[11px] font-semibold transition active:scale-95 sm:text-xs',
            item.className,
          ]}
          {...(item.external
            ? { target: '_blank', rel: 'noopener noreferrer' }
            : {})}
        >
          <Icon name={item.icon} size={20} />
          {item.label}
        </a>
      ))
    }
  </div>
</nav>
<div class="h-16 xl:hidden" aria-hidden="true"></div>
