---
import type { BookingSite } from '@/utils/booking';
import { BOOK_PATH, whatsappHref, generalWhatsAppMessage } from '@/utils/booking';
import Icon from '@/components/Icon.astro';

interface Props {
  site: BookingSite;
}

const { site } = Astro.props;
const wa = whatsappHref(site.whatsapp, generalWhatsAppMessage());
---

<nav
  class="fixed bottom-0 left-0 right-0 z-40 border-t border-slate-200 bg-white/95 px-3 py-2 shadow-lg backdrop-blur-md md:hidden"
  aria-label="Quick booking"
>
  <div class="mx-auto flex max-w-lg items-center justify-between gap-2">
    <a
      href={`tel:${site.phone}`}
      class="flex flex-1 flex-col items-center gap-0.5 rounded-lg py-1.5 text-xs font-semibold text-slate-700 transition active:scale-95"
    >
      <Icon name="phone" size={20} class="text-brand-600" />
      Call
    </a>
    <a
      href={wa}
      target="_blank"
      rel="noopener noreferrer"
      class="flex flex-1 flex-col items-center gap-0.5 rounded-lg py-1.5 text-xs font-semibold text-whatsapp-dark transition active:scale-95"
    >
      <Icon name="whatsapp" size={20} />
      WhatsApp
    </a>
    <a
      href={BOOK_PATH}
      class="btn-primary flex-[1.2] flex-col gap-0.5 py-2 text-xs"
    >
      Book now
    </a>
  </div>
</nav>
<div class="h-16 md:hidden" aria-hidden="true"></div>
