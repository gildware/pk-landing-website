---
import type { BookingSite } from '@/utils/booking';
import { BOOK_PATH, whatsappHref, generalWhatsAppMessage } from '@/utils/booking';

interface Props {
  site: BookingSite;
}

const { site } = Astro.props;
const wa = whatsappHref(site.whatsapp, generalWhatsAppMessage());

const itemClass =
  'flex flex-1 flex-col items-center gap-1 rounded-lg py-1.5 text-[11px] font-semibold transition active:scale-95 sm:text-xs';
---

<nav
  class="fixed bottom-0 left-0 right-0 z-40 border-t border-slate-200 bg-white/95 px-2 py-2 shadow-lg backdrop-blur-md xl:hidden"
  aria-label="Quick booking"
>
  <div class="mx-auto flex max-w-2xl items-center justify-between gap-1 sm:gap-2">
    <a href={`tel:${site.phone}`} class:list={[itemClass, 'text-slate-700']}>
      <span class="text-brand-600" aria-hidden="true">
        <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none">
          <path
            d="M8.5 3.75h2.1a1.5 1.5 0 011.45 1.12l.55 2.2a1.5 1.5 0 01-.8 1.7l-1.2.6a11.1 11.1 0 005.03 5.03l.6-1.2a1.5 1.5 0 011.7-.8l2.2.55a1.5 1.5 0 011.12 1.45v2.1A1.75 1.75 0 0119 18.25C11.82 18.25 5.75 12.18 5.75 5A1.75 1.75 0 017.5 3.25"
            fill="currentColor"
            opacity="0.15"
          />
          <path
            d="M8.5 3.75h2.1a1.5 1.5 0 011.45 1.12l.55 2.2a1.5 1.5 0 01-.8 1.7l-1.2.6a11.1 11.1 0 005.03 5.03l.6-1.2a1.5 1.5 0 011.7-.8l2.2.55a1.5 1.5 0 011.12 1.45v2.1A1.75 1.75 0 0119 18.25C11.82 18.25 5.75 12.18 5.75 5A1.75 1.75 0 017.5 3.25"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linejoin="round"
          />
        </svg>
      </span>
      Call us
    </a>

    <a
      href={wa}
      target="_blank"
      rel="noopener noreferrer"
      class:list={[itemClass, 'text-whatsapp-dark']}
    >
      <span aria-hidden="true">
        <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor">
          <path
            d="M12.04 2a9.9 9.9 0 00-8.54 14.84L2 22l5.3-1.39A9.9 9.9 0 1012.04 2z"
            opacity="0.2"
          />
          <path
            d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.08-.3-.15-1.26-.46-2.4-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.14-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.87 1.21 3.07c.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.09 1.76-.72 2.01-1.41.25-.7.25-1.29.17-1.41-.07-.13-.27-.2-.57-.35z"
          />
        </svg>
      </span>
      WhatsApp us
    </a>

    <a href="/download" class:list={[itemClass, 'text-slate-700']}>
      <span class="text-orange-600" aria-hidden="true">
        <!-- Arrow into tray — clearer “download” at small size -->
        <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none">
          <path
            d="M4.5 14.5V17A2.5 2.5 0 007 19.5h10a2.5 2.5 0 002.5-2.5v-2.5"
            fill="currentColor"
            opacity="0.15"
          />
          <path
            d="M12 3.5v10.25m0 0l3.5-3.5M12 13.75l-3.5-3.5"
            stroke="currentColor"
            stroke-width="1.85"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <path
            d="M4.5 14.5V17A2.5 2.5 0 007 19.5h10a2.5 2.5 0 002.5-2.5v-2.5"
            stroke="currentColor"
            stroke-width="1.85"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </span>
      Download app
    </a>

    <a href={BOOK_PATH} class:list={[itemClass, 'text-slate-700']}>
      <span class="text-brand-600" aria-hidden="true">
        <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none">
          <rect x="3" y="5" width="18" height="16" rx="3" fill="currentColor" opacity="0.15" />
          <path
            d="M8 3.75v2.5M16 3.75v2.5"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
          />
          <rect
            x="3"
            y="5"
            width="18"
            height="16"
            rx="3"
            stroke="currentColor"
            stroke-width="1.75"
          />
          <path d="M3.75 10h16.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
          <path
            d="M12 13v5M9.5 15.5h5"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
          />
        </svg>
      </span>
      Book now
    </a>
  </div>
</nav>
<div class="h-16 xl:hidden" aria-hidden="true"></div>
