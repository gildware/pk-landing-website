---
import type { BookingSite } from '@/utils/booking';
import WhatsAppButton from '@/components/WhatsAppButton.astro';
import { groupServices } from '@/utils/serviceGroups';

interface ServiceOption {
  slug: string;
  shortName: string;
}

interface Props {
  site: BookingSite;
  services: ServiceOption[];
  formId?: string;
  heading?: string;
  variant?: 'full' | 'compact';
  /** Slimmer hero form: shorter copy, submit-only (call/WhatsApp live outside). */
  heroMode?: boolean;
}

const {
  site,
  services,
  formId = 'partner-application-form',
  heading = 'Apply to become a partner',
  variant = 'full',
  heroMode = false,
} = Astro.props;

const compact = variant === 'compact';
const apiBaseUrl = (import.meta.env.PUBLIC_ADMIN_API_URL ?? '').replace(/\/$/, '');
const serviceGroups = groupServices(services);
const serviceOptions = [
  ...serviceGroups.flatMap((group) =>
    group.services.map((s) => ({ group: group.label, value: s.shortName })),
  ),
  { group: '', value: 'Other / Multiple services' },
];

const inputClass =
  'field-input mt-1 w-full rounded-xl border border-slate-400 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200';
const textareaClass = `${inputClass} resize-y py-3`;
const labelClass = 'block text-sm font-medium text-slate-800';
const errorClass = 'field-error mt-1 text-xs text-red-600';
---

<section
  class:list={[compact ? 'w-full' : 'mx-auto max-w-2xl']}
  id={compact ? undefined : 'partner-form'}
>
  {
    compact ? (
      <div>
        <h2 class="text-lg font-extrabold text-slate-900 sm:text-xl">{heading}</h2>
        {!heroMode && (
          <p class="mt-0.5 text-xs text-slate-500 sm:text-sm">We review applications by call or WhatsApp.</p>
        )}
        {heroMode && (
          <p class="mt-0.5 text-xs text-slate-500">Takes about a minute. We’ll contact you next.</p>
        )}
      </div>
    ) : (
      <>
        <h2 class="text-2xl font-bold text-slate-900">{heading}</h2>
        <p class="mt-2 text-sm text-slate-600">
          Share your details and our team will review your application. Prefer WhatsApp?
          Send the same info instantly, or download the{' '}
          <a href="/download#partner" class="font-medium text-brand-700 hover:underline">Partner app</a>.
        </p>
      </>
    )
  }

  <form
    id={formId}
    novalidate
    class:list={[
      'space-y-3 sm:space-y-4',
      compact ? 'mt-3 sm:mt-4' : 'mt-8 space-y-5 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8',
    ]}
  >
    <div class:list={[compact && 'grid gap-4 sm:grid-cols-2']}>
      <div data-field="name">
        <label for={`${formId}-name`} class={labelClass}>Your name *</label>
        <input
          id={`${formId}-name`}
          name="name"
          type="text"
          autocomplete="name"
          class={inputClass}
          placeholder="Full name"
        />
        <p class={`${errorClass} hidden`} role="alert"></p>
      </div>
      <div class={compact ? '' : 'mt-0'} data-field="phone">
        <label for={`${formId}-phone`} class={labelClass}>Phone *</label>
        <input
          id={`${formId}-phone`}
          name="phone"
          type="tel"
          autocomplete="tel"
          class={inputClass}
          placeholder="+91 98765 43210"
        />
        <p class={`${errorClass} hidden`} role="alert"></p>
      </div>
    </div>

    <div class:list={[compact && 'grid gap-4 sm:grid-cols-2']}>
      <div class="searchable-select relative" data-field="service" data-service-search>
        <label for={`${formId}-service-search`} class={labelClass}>Service you offer *</label>
        <input type="hidden" id={`${formId}-service`} name="service" value="" />
        <div class="relative mt-1">
          <input
            id={`${formId}-service-search`}
            type="text"
            role="combobox"
            aria-expanded="false"
            aria-controls={`${formId}-service-list`}
            aria-autocomplete="list"
            autocomplete="off"
            class={inputClass}
            placeholder="Search or select a service"
          />
          <ul
            id={`${formId}-service-list`}
            role="listbox"
            class="absolute z-20 mt-1 hidden max-h-56 w-full overflow-y-auto rounded-xl border border-slate-200 bg-white py-1 shadow-lg"
          ></ul>
        </div>
        <p class={`${errorClass} hidden`} role="alert"></p>
      </div>
      <div data-field="area">
        <label for={`${formId}-area`} class={labelClass}>Areas you can serve *</label>
        <input
          id={`${formId}-area`}
          name="area"
          type="text"
          autocomplete="address-level2"
          class={inputClass}
          placeholder="e.g. Srinagar, Lal Chowk, Bemina"
        />
        <p class={`${errorClass} hidden`} role="alert"></p>
      </div>
    </div>

    {
      !compact && (
        <div>
          <label for={`${formId}-experience`} class={labelClass}>Experience</label>
          <input
            id={`${formId}-experience`}
            name="experience"
            type="text"
            class={inputClass}
            placeholder="e.g. 5 years as a plumber"
          />
        </div>
      )
    }

    <div data-field="message">
      <label for={`${formId}-message`} class={labelClass}>About your work *</label>
      <textarea
        id={`${formId}-message`}
        name="message"
        rows={compact ? 2 : 3}
        class:list={[textareaClass, !compact && 'min-h-[7rem]']}
        placeholder={compact ? 'Briefly describe your skills...' : 'Tell us about your skills, tools, and the jobs you handle...'}
      ></textarea>
      <p class={`${errorClass} hidden`} role="alert"></p>
      {compact && <input type="hidden" name="experience" value="" />}
    </div>

    <div class="flex flex-col gap-2 sm:flex-row">
      {
        !heroMode && (
          <WhatsAppButton
            type="button"
            label="Send on WhatsApp"
            dataAction="whatsapp"
            class="flex-1 py-2.5 text-sm"
          />
        )
      }
      <button
        type="button"
        data-action="submit"
        data-submit-label="Submit application"
        class:list={[
          'rounded-xl bg-brand-600 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-brand-700 disabled:cursor-not-allowed disabled:opacity-70',
          heroMode ? 'w-full' : 'flex-1',
        ]}
      >
        Submit application
      </button>
    </div>
    <p id={`${formId}-submit-error`} class="hidden text-center text-xs text-red-600 sm:text-sm" role="alert"></p>
    {
      !heroMode && (
        <p class="text-center text-[11px] text-slate-500 sm:text-xs">
          Or call <a href={`tel:${site.phone}`} class="font-medium text-brand-700">{site.phone}</a>
        </p>
      )
    }
  </form>

  <div id={`${formId}-success`} class="mt-4 hidden rounded-xl border border-green-200 bg-green-50 p-4 text-sm text-green-900">
    <p class="font-bold">Thanks — we received your application!</p>
    <p class="mt-1">Our team will call or WhatsApp you shortly to continue verification.</p>
    <div class="mt-3 flex flex-wrap gap-2">
      <a href={`tel:${site.phone}`} class="rounded-lg bg-white px-3 py-1.5 text-sm font-semibold text-brand-700 shadow-sm">Call</a>
      <WhatsAppButton id={`${formId}-success-wa`} href="#" label="Send on WhatsApp" class="px-3 py-1.5 text-sm" />
    </div>
  </div>
</section>

<script define:vars={{ formId, apiBaseUrl, whatsapp: site.whatsapp, serviceOptions }}>
  const form = document.getElementById(formId);
  const success = document.getElementById(`${formId}-success`);
  const successWa = document.getElementById(`${formId}-success-wa`);
  const submitError = document.getElementById(`${formId}-submit-error`);
  const submitButton = form?.querySelector('button[data-action="submit"]');

  const serviceInput = document.getElementById(`${formId}-service`);
  const serviceSearch = document.getElementById(`${formId}-service-search`);
  const serviceList = document.getElementById(`${formId}-service-list`);

  const validServiceValues = new Set(serviceOptions.map((opt) => opt.value));
  const errorBorderClasses = ['border-red-500', 'focus:border-red-500', 'focus:ring-red-200'];
  const normalBorderClasses = ['border-slate-400', 'focus:border-brand-500', 'focus:ring-brand-200'];

  let activeOptionIndex = -1;

  function digits(w) {
    return String(w).replace(/\D/g, '');
  }

  function buildMessage(data) {
    return [
      "Hello Panun Kaergar, I'd like to join as a service partner.",
      `Name: ${data.name}`,
      `Phone: ${data.phone}`,
      `Service: ${data.service}`,
      `Areas: ${data.area}`,
      data.experience ? `Experience: ${data.experience}` : '',
      data.message ? `About me: ${data.message}` : '',
      '',
      'Sent via panunkaergar.com partner form',
    ]
      .filter(Boolean)
      .join('\n');
  }

  function getData(formEl) {
    return {
      name: formEl.name.value.trim(),
      phone: formEl.phone.value.trim(),
      service: formEl.service.value.trim(),
      area: formEl.area.value.trim(),
      experience: formEl.experience?.value?.trim() ?? '',
      message: formEl.message.value.trim(),
    };
  }

  function getFieldInput(fieldName) {
    if (fieldName === 'service') return serviceSearch;
    return form?.elements.namedItem(fieldName);
  }

  function setFieldError(fieldName, message) {
    const group = form?.querySelector(`[data-field="${fieldName}"]`);
    const input = getFieldInput(fieldName);
    const errorEl = group?.querySelector('.field-error');
    if (!input || !errorEl) return;

    input.classList.remove(...normalBorderClasses);
    input.classList.add(...errorBorderClasses);
    input.setAttribute('aria-invalid', 'true');
    errorEl.textContent = message;
    errorEl.classList.remove('hidden');
  }

  function clearFieldError(fieldName) {
    const group = form?.querySelector(`[data-field="${fieldName}"]`);
    const input = getFieldInput(fieldName);
    const errorEl = group?.querySelector('.field-error');
    if (!input || !errorEl) return;

    input.classList.remove(...errorBorderClasses);
    input.classList.add(...normalBorderClasses);
    input.removeAttribute('aria-invalid');
    errorEl.textContent = '';
    errorEl.classList.add('hidden');
  }

  function clearAllErrors() {
    for (const fieldName of ['name', 'phone', 'service', 'area', 'message']) {
      clearFieldError(fieldName);
    }
  }

  function validateForm() {
    const data = getData(form);
    const errors = {};

    if (!data.name) {
      errors.name = 'Please enter your name.';
    }

    if (!data.phone) {
      errors.phone = 'Please enter your phone number.';
    } else if (digits(data.phone).length < 10) {
      errors.phone = 'Enter a valid 10-digit phone number.';
    }

    if (!data.service || !validServiceValues.has(data.service)) {
      errors.service = 'Please select a service from the list.';
    }

    if (!data.area) {
      errors.area = 'Please enter the areas you can serve.';
    }

    if (!data.message) {
      errors.message = 'Please tell us about your work.';
    }

    return errors;
  }

  function showErrors(errors) {
    clearAllErrors();
    for (const [fieldName, message] of Object.entries(errors)) {
      setFieldError(fieldName, message);
    }

    const firstInvalid = Object.keys(errors)[0];
    const firstInput = getFieldInput(firstInvalid);
    firstInput?.focus();
  }

  for (const fieldName of ['name', 'phone', 'area', 'message']) {
    const input = getFieldInput(fieldName);
    input?.addEventListener('input', () => clearFieldError(fieldName));
  }

  function renderServiceOptions(query = '') {
    if (!serviceList) return;
    const q = query.trim().toLowerCase();
    const matches = serviceOptions.filter((opt) => {
      const haystack = `${opt.group} ${opt.value}`.toLowerCase();
      return !q || haystack.includes(q);
    });

    serviceList.innerHTML = '';
    activeOptionIndex = -1;

    if (matches.length === 0) {
      const empty = document.createElement('li');
      empty.className = 'px-3 py-2 text-sm text-slate-500';
      empty.textContent = 'No matching services';
      serviceList.appendChild(empty);
      return;
    }

    let lastGroup = null;
    for (const opt of matches) {
      if (opt.group && opt.group !== lastGroup) {
        const heading = document.createElement('li');
        heading.className = 'px-3 py-1.5 text-xs font-semibold uppercase tracking-wide text-slate-500';
        heading.setAttribute('role', 'presentation');
        heading.textContent = opt.group;
        serviceList.appendChild(heading);
        lastGroup = opt.group;
      }

      const item = document.createElement('li');
      item.setAttribute('role', 'option');
      item.dataset.value = opt.value;
      item.className =
        'cursor-pointer px-3 py-2 text-sm text-slate-900 hover:bg-brand-50 aria-selected:bg-brand-100';
      item.textContent = opt.value;
      serviceList.appendChild(item);
    }
  }

  function openServiceList() {
    if (!serviceList || !serviceSearch) return;
    renderServiceOptions(serviceSearch.value);
    serviceList.classList.remove('hidden');
    serviceSearch.setAttribute('aria-expanded', 'true');
  }

  function closeServiceList() {
    if (!serviceList || !serviceSearch) return;
    serviceList.classList.add('hidden');
    serviceSearch.setAttribute('aria-expanded', 'false');
    activeOptionIndex = -1;
  }

  function selectService(value) {
    if (!serviceInput || !serviceSearch) return;
    serviceInput.value = value;
    serviceSearch.value = value;
    clearFieldError('service');
    closeServiceList();
  }

  function getServiceOptionElements() {
    return serviceList ? [...serviceList.querySelectorAll('[role="option"]')] : [];
  }

  function highlightServiceOption(index) {
    const options = getServiceOptionElements();
    options.forEach((el, i) => {
      el.setAttribute('aria-selected', i === index ? 'true' : 'false');
      el.classList.toggle('bg-brand-50', i === index);
    });
    if (options[index]) {
      options[index].scrollIntoView({ block: 'nearest' });
    }
  }

  serviceSearch?.addEventListener('focus', openServiceList);
  serviceSearch?.addEventListener('input', () => {
    if (serviceInput) serviceInput.value = '';
    clearFieldError('service');
    openServiceList();
  });

  serviceSearch?.addEventListener('keydown', (e) => {
    const options = getServiceOptionElements();
    if (!options.length) {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        openServiceList();
      }
      return;
    }

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeOptionIndex = Math.min(activeOptionIndex + 1, options.length - 1);
      highlightServiceOption(activeOptionIndex);
      return;
    }

    if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeOptionIndex = Math.max(activeOptionIndex - 1, 0);
      highlightServiceOption(activeOptionIndex);
      return;
    }

    if (e.key === 'Enter' && activeOptionIndex >= 0) {
      e.preventDefault();
      selectService(options[activeOptionIndex].dataset.value ?? '');
      return;
    }

    if (e.key === 'Escape') {
      closeServiceList();
    }
  });

  serviceList?.addEventListener('mousedown', (e) => {
    const option = e.target.closest('[role="option"]');
    if (!option) return;
    e.preventDefault();
    selectService(option.dataset.value ?? '');
  });

  document.addEventListener('click', (e) => {
    const wrapper = serviceSearch?.closest('.searchable-select');
    if (wrapper && !wrapper.contains(e.target)) {
      closeServiceList();
    }
  });

  function clearSubmitError() {
    if (!submitError) return;
    submitError.textContent = '';
    submitError.classList.add('hidden');
  }

  function showSubmitError(message) {
    if (!submitError) return;
    submitError.textContent = message;
    submitError.classList.remove('hidden');
  }

  function setSubmitting(isSubmitting) {
    if (!submitButton) return;
    const defaultLabel = submitButton.dataset.submitLabel || 'Submit application';
    submitButton.disabled = isSubmitting;
    submitButton.textContent = isSubmitting ? 'Submitting...' : defaultLabel;
  }

  async function submitToBackend(data) {
    if (!apiBaseUrl) {
      throw new Error('Applications are temporarily unavailable. Please use WhatsApp or call us.');
    }

    const response = await fetch(`${apiBaseUrl}/api/v1/public/web-provider-request/submit`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify({
        name: data.name,
        phone: data.phone,
        service: data.service,
        area: data.area,
        experience: data.experience,
        message: data.message,
      }),
    });

    const result = await response.json().catch(() => ({}));
    if (!response.ok || result.response_code !== 'default_store_200') {
      const firstError = Array.isArray(result.errors) && result.errors[0]?.message
        ? result.errors[0].message
        : result.message || 'Could not submit your application. Please try WhatsApp or call us.';
      throw new Error(firstError);
    }

    return result;
  }

  form?.addEventListener('click', (e) => {
    const btn = e.target.closest('button[data-action]');
    if (!btn || !form.contains(btn)) return;
    e.preventDefault();

    const errors = validateForm();
    if (Object.keys(errors).length > 0) {
      showErrors(errors);
      return;
    }

    clearSubmitError();
    const data = getData(form);
    const msg = buildMessage(data);
    const waUrl = `https://wa.me/${digits(whatsapp)}?text=${encodeURIComponent(msg)}`;

    if (btn.dataset.action === 'whatsapp') {
      window.open(waUrl, '_blank', 'noopener,noreferrer');
      return;
    }

    setSubmitting(true);
    submitToBackend(data)
      .then(() => showSuccess(waUrl))
      .catch((error) => {
        showSubmitError(error?.message || 'Could not submit your application. Please try WhatsApp or call us.');
      })
      .finally(() => setSubmitting(false));
  });

  function showSuccess(waUrl) {
    form.classList.add('hidden');
    success?.classList.remove('hidden');
    if (successWa) successWa.href = waUrl;
  }
</script>
