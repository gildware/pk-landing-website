---
interface Props {
  store: 'google-play' | 'app-store';
  href: string;
  class?: string;
}

const { store, href, class: className = '' } = Astro.props;
const isPlay = store === 'google-play';
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    'inline-flex items-center gap-3 rounded-xl px-5 py-2.5 transition hover:opacity-90 active:scale-[0.98]',
    isPlay ? 'bg-slate-900 text-white hover:bg-slate-800' : 'bg-slate-900 text-white hover:bg-slate-800',
    className,
  ]}
>
  {
    isPlay ? (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true" class="shrink-0">
        <path d="M3.6 1.8c-.3.2-.6.6-.6 1.1v18.2c0 .5.3.9.6 1.1l.1.1 10.2-10.2v-.2L3.7 1.7l-.1.1z"/>
        <path d="M14.3 12 3.7 22.6c.2.2.5.3.8.3.3 0 .6-.1.9-.3l11.4-6.6-2.5-1.5-2.5-1.5z"/>
        <path d="M14.3 12 3.7 1.4c.3-.2.6-.3.9-.3.3 0 .6.1.8.3l11.4 6.6-2.5 1.5z"/>
        <path d="M16.8 13.5 14.3 12l2.5-1.5 2.5-1.5c.7.4 1.2 1.2 1.2 2.1s-.5 1.7-1.2 2.1l-2.5-1.5z"/>
      </svg>
    ) : (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true" class="shrink-0">
        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
      </svg>
    )
  }
  <span class="flex flex-col leading-tight text-left">
    <span class="text-[10px] font-medium uppercase tracking-wide opacity-80">
      {isPlay ? 'Get it on' : 'Download on the'}
    </span>
    <span class="text-base font-semibold">{isPlay ? 'Google Play' : 'App Store'}</span>
  </span>
</a>
