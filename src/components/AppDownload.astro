---
import StoreButton from '@/components/StoreButton.astro';
import { BOOK_PATH } from '@/utils/booking';

interface Props {
  userPlayStoreUrl: string;
  userAppStoreUrl: string;
  providerPlayStoreUrl: string;
  providerAppStoreUrl: string;
  bookingUrl?: string;
}

const {
  userPlayStoreUrl,
  userAppStoreUrl,
  providerPlayStoreUrl,
  providerAppStoreUrl,
  bookingUrl = BOOK_PATH,
} = Astro.props;

const apps = [
  {
    id: 'customer',
    badge: 'For customers',
    title: 'Customer app',
    description:
      'Book home services, track your provider, and pay securely from your phone.',
    playStoreUrl: userPlayStoreUrl,
    appStoreUrl: userAppStoreUrl,
    image: '/images/download/home-customer.webp',
    imageAlt: 'Customer using the Panun Kaergar app on a phone',
    link: { href: bookingUrl, label: 'Book without the app →' },
  },
  {
    id: 'partner',
    badge: 'For partners',
    title: 'Provider app',
    description:
      'Get booking requests, manage jobs, and grow your earnings as a verified partner.',
    playStoreUrl: providerPlayStoreUrl,
    appStoreUrl: providerAppStoreUrl,
    image: '/images/download/home-provider.webp',
    imageAlt: 'Partner using the Panun Kaergar Provider app on a phone',
    link: { href: '/become-a-partner', label: 'Become a partner →' },
  },
];
---

<section class="section-pad border-y border-slate-200 bg-gradient-to-br from-slate-50 to-white">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-slate-900">Download the Panun Kaergar apps</h2>
      <p class="mt-3 text-slate-600">
        Free on Android and iOS — book as a customer, or earn as a partner.
      </p>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      {
        apps.map((app, i) => (
          <article
            class:list={[
              'reveal card flex overflow-hidden',
              i === 1 && 'reveal-stagger-2',
            ]}
          >
            <div class="w-36 shrink-0 self-stretch sm:w-40">
              <img
                src={app.image}
                alt={app.imageAlt}
                width="320"
                height="400"
                class="h-full w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>

            <div class="flex min-w-0 flex-1 flex-col justify-center p-5 text-left sm:p-6">
              <span class="inline-flex w-fit rounded-full bg-brand-50 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-brand-700">
                {app.badge}
              </span>
              <h3 class="mt-2 text-lg font-bold text-slate-900">{app.title}</h3>
              <p class="mt-1 text-sm leading-relaxed text-slate-600">{app.description}</p>

              <div class="mt-4 flex flex-wrap gap-2">
                <StoreButton store="google-play" href={app.playStoreUrl} class="!px-3 !py-2 scale-90 origin-left" />
                <StoreButton store="app-store" href={app.appStoreUrl} class="!px-3 !py-2 scale-90 origin-left" />
              </div>

              <a
                href={app.link.href}
                class="mt-3 inline-flex items-center gap-1 text-xs font-semibold text-brand-700 transition-all duration-300 ease-smooth hover:gap-2 hover:underline"
              >
                {app.link.label}
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <p class="reveal mt-8 text-center text-sm text-slate-500">
      <a href="/download" class="font-medium text-brand-700 hover:underline">See all download options →</a>
    </p>
  </div>
</section>
