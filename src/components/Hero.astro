---
import Icon from '@/components/Icon.astro';
import BookServiceForm from '@/components/BookServiceForm.astro';
import type { BookingSite } from '@/utils/booking';

interface ServiceOption {
  slug: string;
  shortName: string;
}

interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  areaName?: string;
  site: BookingSite;
  services: ServiceOption[];
  areaOptions?: string[];
}

const {
  title,
  subtitle,
  badge,
  primaryHref = '/book',
  secondaryHref = '/become-a-provider',
  secondaryLabel = 'Become a provider',
  areaName = 'Srinagar',
  site,
  services,
  areaOptions,
} = Astro.props;

const trustItems = [
  { icon: 'shield-check', text: 'Verified providers' },
  { icon: 'map-pin', text: 'Serving Srinagar' },
  { icon: 'clock', text: 'Book any time slot' },
];
---

<section class="relative bg-gradient-to-br from-brand-900 via-brand-600 to-brand-700 text-white">
  <div class="absolute inset-0 overflow-hidden opacity-30" aria-hidden="true">
    <div class="absolute -left-24 top-0 h-80 w-80 rounded-full bg-white/20 blur-3xl animate-blob-drift"></div>
    <div class="absolute bottom-0 right-0 h-96 w-96 rounded-full bg-sky-300/20 blur-3xl animate-blob-drift [animation-delay:4s]"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12 lg:py-24">
    <div class="flex flex-col gap-6 lg:grid lg:grid-cols-2 lg:items-start lg:gap-14">
      <!-- Booking form first on mobile -->
      <div class="order-1 lg:order-2">
        <h1 class="mb-3 line-clamp-3 text-xl font-extrabold leading-snug text-white sm:text-2xl lg:hidden">
          {title}
        </h1>
        <div class="scroll-mt-24 rounded-2xl bg-white p-4 shadow-2xl sm:p-6" id="book-form">
          <BookServiceForm
            site={site}
            services={services}
            areas={areaOptions}
            formId="hero-book-form"
            heading={`Book in ${areaName}`}
            variant="compact"
          />
        </div>
      </div>

      <!-- Marketing copy — trimmed on mobile -->
      <div class="order-2 lg:order-1 lg:pt-2">
        {
          badge && (
            <p class="hidden items-center rounded-full border border-white/25 bg-white/10 px-3.5 py-1.5 text-xs font-semibold uppercase tracking-wider text-white/90 sm:inline-flex">
              {badge}
            </p>
          )
        }
        <h1 class="hidden text-4xl font-extrabold leading-tight text-white sm:mt-5 lg:block lg:text-[3.25rem] lg:leading-[1.1]">
          {title}
        </h1>
        {
          subtitle && (
            <p class="mt-3 hidden max-w-xl text-lg leading-relaxed text-white/85 lg:block">{subtitle}</p>
          )
        }

        <ul class="mt-6 hidden flex-wrap gap-x-6 gap-y-3 text-sm text-white/80 lg:flex">
          {trustItems.map((item) => (
            <li class="flex items-center gap-2">
              <Icon name={item.icon} size={17} class="text-white" />
              {item.text}
            </li>
          ))}
        </ul>

        <div class="mt-6 hidden flex-wrap gap-3 lg:flex">
          <a
            href="/download"
            class="inline-flex items-center gap-2 rounded-xl border-2 border-white/40 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-white/10"
          >
            <Icon name="smartphone" size={18} />
            Download app
          </a>
          <a
            href={secondaryHref}
            class="inline-flex items-center rounded-xl px-5 py-2.5 text-sm font-medium text-white/80 transition hover:text-white hover:underline"
          >
            {secondaryLabel} →
          </a>
        </div>

        <p class="mt-4 hidden text-sm text-white/60 lg:block">
          Need the full form? <a href={primaryHref} class="font-medium text-white underline-offset-2 hover:underline">More booking options</a>
        </p>

        <!-- Mobile-only: compact trust line under form area -->
        <p class="mt-4 text-center text-xs text-white/70 lg:hidden">
          Verified providers · Srinagar · Call, WhatsApp, or online form
        </p>
      </div>
    </div>
  </div>
</section>
