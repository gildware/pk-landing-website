---
import Icon from '@/components/Icon.astro';
import BookServiceForm from '@/components/BookServiceForm.astro';
import type { BookingSite } from '@/utils/booking';
import { BOOK_PATH } from '@/utils/booking';

interface ServiceOption {
  slug: string;
  shortName: string;
}

interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  areaName?: string;
  site: BookingSite;
  services: ServiceOption[];
}

const {
  title,
  subtitle,
  badge,
  primaryHref = BOOK_PATH,
  secondaryHref = '/become-a-partner',
  secondaryLabel = 'Become a partner',
  areaName = 'Srinagar',
  site,
  services,
} = Astro.props;

const trustItems = [
  { icon: 'shield-check', text: 'Verified partners' },
  { icon: 'map-pin', text: 'Serving Srinagar' },
  { icon: 'clock', text: 'Book any time slot' },
];
---

<section
  class="relative overflow-hidden bg-brand-900 bg-gradient-to-br from-brand-900 via-brand-600 to-brand-700 text-white"
  style="background-color: #121228; color: #ffffff;"
>
  <div
    class="hero-blob -left-24 top-0 h-72 w-72 bg-brand-500/30"
    style="animation-delay: 0s;"
    aria-hidden="true"
  ></div>
  <div
    class="hero-blob -right-16 bottom-0 h-96 w-96 bg-accent/20"
    style="animation-delay: -5s;"
    aria-hidden="true"
  ></div>
  <div
    class="hero-blob left-1/3 top-1/2 h-48 w-48 bg-white/10"
    style="animation-delay: -9s;"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-6xl px-4 py-6 sm:px-6 sm:py-9 lg:py-14">
    <div class="flex flex-col gap-5 lg:grid lg:grid-cols-2 lg:items-start lg:gap-12">
      <h1
        class="animate-fade-up text-xl font-extrabold leading-snug text-white sm:text-2xl lg:col-start-1 lg:row-start-1 lg:text-[2.85rem] lg:leading-[1.1]"
        style="color: #ffffff;"
      >
        {title}
      </h1>

      <div class="lg:col-start-2 lg:row-start-1 lg:row-span-2">
        <div
          class="animate-slide-right stagger-2 scroll-mt-24 rounded-2xl bg-white p-4 text-slate-900 shadow-2xl transition-shadow duration-500 hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.35)] sm:p-6"
          id="book-form"
          style="background-color: #ffffff; color: #0f172a;"
        >
          <BookServiceForm
            site={site}
            services={services}
            formId="hero-book-form"
            heading={`Book in ${areaName}`}
            variant="compact"
          />
        </div>
      </div>

      <div class="lg:col-start-1 lg:row-start-2">
        {
          badge && (
            <p class="animate-fade-up stagger-1 hidden items-center rounded-full border border-white/25 bg-white/10 px-3.5 py-1.5 text-xs font-semibold uppercase tracking-wider text-white/90 backdrop-blur-sm sm:inline-flex">
              {badge}
            </p>
          )
        }
        {
          subtitle && (
            <p class="animate-fade-up stagger-2 mt-3 hidden max-w-xl text-lg leading-relaxed text-white/85 lg:block">{subtitle}</p>
          )
        }

        <ul class="animate-fade-up stagger-3 mt-6 hidden flex-wrap gap-x-6 gap-y-3 text-sm text-white/80 lg:flex">
          {trustItems.map((item, i) => (
            <li class:list={['flex items-center gap-2', i > 0 && 'animate-fade-in', i === 1 && 'stagger-4', i === 2 && 'stagger-5']}>
              <Icon name={item.icon} size={17} class="text-white" />
              {item.text}
            </li>
          ))}
        </ul>

        <div class="animate-fade-up stagger-4 mt-6 hidden flex-wrap gap-3 lg:flex">
          <a
            href="/download"
            class="inline-flex items-center gap-2 rounded-xl border-2 border-white/40 px-5 py-2.5 text-sm font-semibold text-white transition-all duration-300 ease-smooth hover:-translate-y-0.5 hover:border-white/60 hover:bg-white/10"
          >
            <Icon name="smartphone" size={18} />
            Download app
          </a>
          <a
            href={secondaryHref}
            class="inline-flex items-center rounded-xl px-5 py-2.5 text-sm font-medium text-white/80 transition-all duration-300 ease-smooth hover:-translate-y-0.5 hover:text-white hover:underline"
          >
            {secondaryLabel} →
          </a>
        </div>

        <p class="animate-fade-in stagger-5 mt-4 hidden text-sm text-white/60 lg:block">
          Need the full form? <a href={primaryHref} class="font-medium text-white underline-offset-2 transition-colors hover:underline">More booking options</a>
        </p>

        <p class="animate-fade-up mt-4 text-center text-xs text-white/70 lg:hidden">
          Verified partners · Srinagar · Call, WhatsApp, or online form
        </p>
      </div>
    </div>
  </div>
</section>
